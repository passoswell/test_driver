#############################################
# Utility command for test

build esp-idf/soc/CMakeFiles/test.util: CUSTOM_COMMAND
  COMMAND = cd /home/user/vscode/projects/test_driver/build/esp32/esp-idf/soc && /usr/bin/ctest --force-new-ctest-process
  DESC = Running tests...
  pool = console
  restat = 1

build esp-idf/soc/test: phony esp-idf/soc/CMakeFiles/test.util


#############################################
# Utility command for edit_cache

build esp-idf/soc/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/user/vscode/projects/test_driver/build/esp32/esp-idf/soc && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build esp-idf/soc/edit_cache: phony esp-idf/soc/CMakeFiles/edit_cache.util


#############################################
