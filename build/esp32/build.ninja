build esp-idf/CMakeFiles/install.util: CUSTOM_COMMAND esp-idf/all
  COMMAND = cd /home/user/vscode/projects/test_driver/build/esp32/esp-idf && /usr/bin/cmake -P cmake_install.cmake
  DESC = Install the project...
  pool = console
  restat = 1

build esp-idf/install: phony esp-idf/CMakeFiles/install.util


