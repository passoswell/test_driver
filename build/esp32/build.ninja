build esp-idf/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /home/user/vscode/projects/test_driver/build/esp32/esp-idf && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build esp-idf/edit_cache: phony esp-idf/CMakeFiles/edit_cache.util


#############################################
