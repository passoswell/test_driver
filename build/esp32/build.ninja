#############################################
# Utility command for test

build esp-idf/CMakeFiles/test.util: CUSTOM_COMMAND
  COMMAND = cd /home/user/vscode/projects/test_driver/build/esp32/esp-idf && /usr/bin/ctest --force-new-ctest-process
  DESC = Running tests...
  pool = console
  restat = 1

build esp-idf/test: phony esp-idf/CMakeFiles/test.util


#############################################
